// Liga de Básquetbol Arauco 2026 — schema
// Standings se calculan derivados de Match, no se persisten.

generator client {
  provider      = "prisma-client-js"
  // native = la máquina donde corre `prisma generate` (dev). Los targets adicionales
  // permiten que el cliente funcione en alpine/musl (runtime Docker) sin re-generar.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoundPhase {
  REGULAR
  SEMI
  FINAL
}

enum MatchStatus {
  SCHEDULED
  PLAYED
  POSTPONED
}

model Team {
  id              String  @id @default(cuid())
  slug            String  @unique
  name            String
  shortName       String
  instagramHandle String?
  logoUrl         String?
  logoSvgUrl      String?
  coverPhotoUrl   String?
  primaryColor    String  @default("#0F2A4A")
  secondaryColor  String?

  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")
  players     Player[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Player {
  id     String @id @default(cuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // Datos del jugador. RUT es único globalmente (un jugador no puede estar
  // en dos equipos a la vez), jersey opcional pero único por equipo.
  name     String
  rut      String  @unique
  jersey   Int?
  position String?

  matchStats MatchPlayerStat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teamId])
  @@unique([teamId, jersey])
}

model Round {
  id      String     @id @default(cuid())
  number  Int        @unique
  label   String
  phase   RoundPhase
  date    DateTime

  matches Match[]
}

model Match {
  id     String @id @default(cuid())
  number Int    @unique

  roundId String
  round   Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)

  scheduledAt DateTime

  homeTeamId String?
  awayTeamId String?
  homeTeam   Team?   @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam   Team?   @relation("AwayTeam", fields: [awayTeamId], references: [id])

  homePlaceholder String?
  awayPlaceholder String?

  homeScore Int?
  awayScore Int?

  status MatchStatus @default(SCHEDULED)
  notes  String?

  // Nuestro Momento integration (spec 2026-05-004).
  // Cada partido se sincroniza como un "evento" en NM para alojar la galería
  // de fotos. nmEventId se setea tras la primera sincronización exitosa;
  // mientras sea null, el partido aún no tiene galería.
  nmEventId   String?   @map("nm_event_id")
  nmEventSlug String?   @map("nm_event_slug")
  nmSyncedAt  DateTime? @map("nm_synced_at")

  periods     MatchPeriod[]
  playerStats MatchPlayerStat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roundId])
  @@index([scheduledAt])
  @@index([nmEventId])
}

// Stats por período (cuartos + OT) del partido. Reglas:
// - period 1..4 = cuartos regulares; 5+ = tiempos extra (OT1=5, OT2=6, ...)
// - homePoints/awayPoints son los puntos anotados EN ese período (parcial),
//   no acumulados. El total del partido se calcula sumando todos los períodos
//   y se persiste en Match.homeScore/Match.awayScore.
// - homeTeamFouls/awayTeamFouls son faltas colectivas (no individuales).
model MatchPeriod {
  id      String @id @default(cuid())
  matchId String
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  period         Int
  homePoints     Int
  awayPoints     Int
  homeTeamFouls  Int @default(0)
  awayTeamFouls  Int @default(0)
  homeTimeouts   Int @default(0)
  awayTimeouts   Int @default(0)

  @@unique([matchId, period])
  @@index([matchId])
}

// Estadísticas por jugador en un partido. Un row por jugador del roster que
// participó O cuyo total se quiere guardar. Si played=false con points=0 y
// fouls=0, el jugador estuvo en banca sin entrar.
model MatchPlayerStat {
  id      String @id @default(cuid())
  matchId String
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  teamId   String

  played Boolean @default(false)
  points Int     @default(0)
  fouls  Int     @default(0)

  @@unique([matchId, playerId])
  @@index([matchId, teamId])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}
